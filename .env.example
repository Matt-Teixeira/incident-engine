# incident-engine — copy to .env and fill in. .env is gitignored; never commit
# secret values. Variable rules: markdown/ENVIRONMENT.md.

# --- Identity / logging ---
APP_NAME=incident-engine
LOGGER=staging
RUN_ENV=staging
# host:container bind spec for the per-run JSON logs (host dir must be writable by 105:987)
RUN_LOGS_DIR=/opt/run-logs/incident-engine:/opt/run-logs/incident-engine

# --- PostgreSQL (least-privilege owner of the incidents schema) ---
PGHOST=pg_db
PGPORT=5432
PGDATABASE=staging
PGUSER=incident_engine_rw
PGPASSWORD=change-me
# verify-full = CA + hostname verification (fail-closed if the CA is missing).
# `require` (encrypted, unauthenticated) is a documented exception, not a default.
PG_SSLMODE=verify-full
PG_SSL_PATH=/opt/resources/ssl/pg_ssl.crt

# --- Pipeline (defaults; consumed from Phase 2 on) ---
ASSESSOR_KIND=rules
# MATERIALIZE_OVERLAP_MS=5000
# MATERIALIZE_BATCH_ROWS=5000
# ASSESS_WINDOW_HOURS=24
